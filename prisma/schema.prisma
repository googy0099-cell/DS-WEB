generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  passwordHash  String?
  googleId      String?    @unique
  firstName     String
  lastName      String
  username      String     @unique
  phone         String?    @unique
  memberCode    String     @unique
  nickname      String?
  instagram     String?
  facebook      String?
  birthday      String?
  avatarUrl     String?
  visitCount    Int        @default(0)
  points        Int        @default(0)
  dicePoints    Int        @default(0)
  playMinutes   Int        @default(0)
  totalSpentTHB Int        @default(0)
  role          String     @default("USER")
  memberSessions      PlayerSession[]      @relation("MemberSessions")
  orders              Order[]              @relation("CustomerOrders")
  handledOrders       Order[]              @relation("StaffOrders")
  auditLogs           AuditLog[]
  cashDrawerSessions  CashDrawerSession[] @relation("DrawerClosedBy")
  stockInLogs         StockInLog[]        @relation("StockInLogs")
  stockOutLogs        StockOutLog[]       @relation("StockOutLogs")
  shopSessions        ShopSession[]       @relation("ShopSessions")
  notifications          Notification[]
  werewolfRoomsGM        WerewolfRoom[]          @relation("WerewolfRoomsGM")
  werewolfRoomPlayers    WerewolfRoomPlayer[]    @relation("WerewolfRoomPlayers")
  werewolfGamesGM        WerewolfGame[]          @relation("WerewolfGamesGM")
  werewolfGameResults    WerewolfGameResult[]    @relation("WerewolfGameResults")
  werewolfSessionPlayers WerewolfSessionPlayer[] @relation("WerewolfSessionPlayers")
  hrStaff             HrStaff?             @relation("HrStaff")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Table {
  id             Int             @id @default(autoincrement())
  number         Int             @unique
  slug           String?         @unique
  isOccupied     Boolean         @default(false)
  orders         Order[]
  playerSessions PlayerSession[]
  bills          Bill[]
}

model Bill {
  id             Int             @id @default(autoincrement())
  name           String
  color          String          @default("indigo")
  tableId        Int
  table          Table           @relation(fields: [tableId], references: [id])
  status         String          @default("ACTIVE")
  startsAt       DateTime
  sessions       PlayerSession[]
  orders         Order[]         @relation("BillOrders")
  discountType   String?  @map("discount_type")
  discountValue  Int?     @map("discount_value")
  discountAmount Int?     @map("discount_amount")
  discountNote   String?  @map("discount_note")
  isTest         Boolean         @default(false) @map("is_test")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PlayerSession {
  id            Int      @id @default(autoincrement())
  tableId       Int
  table         Table    @relation(fields: [tableId], references: [id])
  nickname      String
  packageType   String
  packagePrice  Int      @default(0)
  timeRemaining Int
  status        String   @default("ACTIVE")
  userId        Int?
  user          User?    @relation("MemberSessions", fields: [userId], references: [id])
  billId        Int?
  bill          Bill?    @relation(fields: [billId], references: [id])
  orders        Order[]
  isTest        Boolean  @default(false) @map("is_test")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MenuItem {
  id            Int                   @id @default(autoincrement())
  nameTh        String
  nameEn        String
  category      String
  priceTHB      Int
  priceS        Int?
  priceXL       Int?
  imageUrl      String?
  isAvailable   Boolean               @default(true)
  isFeatured    Boolean               @default(false)
  sellStartTime String?
  sellEndTime   String?
  recipeNote    String?               @map("recipe_note")
  queueTarget   String                @default("kitchen") @map("queue_target")
  orderItems    OrderItem[]
  addonGroups   MenuItemAddonGroup[]
  optionGroups  MenuItemOptionGroup[]
  stockRecipes  MenuStockRecipe[]
}

model RewardItem {
  id          Int      @id @default(autoincrement())
  nameTh      String
  description String   @default("")
  cost        Int      @default(10)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model MiniGame {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  htmlUrl     String
  coverUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AddonGroup {
  id        Int                  @id @default(autoincrement())
  nameTh    String
  isActive  Boolean              @default(true)
  items     AddonItem[]
  menuItems MenuItemAddonGroup[]
}

model AddonItem {
  id           Int        @id @default(autoincrement())
  addonGroupId Int
  addonGroup   AddonGroup @relation(fields: [addonGroupId], references: [id])
  nameTh       String
  priceTHB     Int
  isActive     Boolean    @default(true)
}

model OptionGroup {
  id         Int                   @id @default(autoincrement())
  nameTh     String
  isRequired Boolean               @default(false)
  isActive   Boolean               @default(true)
  choices    OptionChoice[]
  menuItems  MenuItemOptionGroup[]
}

model OptionChoice {
  id            Int         @id @default(autoincrement())
  optionGroupId Int
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  nameTh        String
  priceTHB      Int         @default(0)
  isDefault     Boolean     @default(false)
  isActive      Boolean     @default(true)
}

model MenuItemAddonGroup {
  menuItemId   Int
  addonGroupId Int
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  addonGroup   AddonGroup @relation(fields: [addonGroupId], references: [id])
  @@id([menuItemId, addonGroupId])
}

model MenuItemOptionGroup {
  menuItemId    Int
  optionGroupId Int
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id])
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  @@id([menuItemId, optionGroupId])
}

model Order {
  id              Int            @id @default(autoincrement())
  orderName       String         @default("")
  userId          Int?
  user            User?          @relation("CustomerOrders", fields: [userId], references: [id])
  handledById     Int?
  handledBy       User?          @relation("StaffOrders", fields: [handledById], references: [id])
  tableId         Int?
  table           Table?         @relation(fields: [tableId], references: [id])
  billId          Int?
  bill            Bill?          @relation("BillOrders", fields: [billId], references: [id])
  playerSessionId Int?
  playerSession   PlayerSession? @relation(fields: [playerSessionId], references: [id])
  status          String         @default("PENDING")
  totalTHB        Int
  discountAmount  Int?           // single-order discount (net = totalTHB − discountAmount)
  note            String?
  kitchenServedAt DateTime?
  items           OrderItem[]
  payment         Payment?
  splitPayments   SplitPayment[]
  isTest          Boolean        @default(false) @map("is_test")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model OrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  order           Order     @relation(fields: [orderId], references: [id])
  menuItemId      Int
  menuItem        MenuItem  @relation(fields: [menuItemId], references: [id])
  quantity        Int
  unitPriceTHB    Int
  selectedSize    String?
  selectedAddons  String?
  selectedOptions String?
  kitchenServedAt DateTime?
  cancelledAt     DateTime? @map("cancelled_at")
}

model Payment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  order          Order     @relation(fields: [orderId], references: [id])
  method         String
  amountTHB      Int
  status         String    @default("PENDING")
  slipUrl        String?
  confirmedAt    DateTime?
  staffNote      String?
  receivedAmount Int?
  changeAmount   Int?
  splitCashTHB   Int?      // แบ่งจ่ายออเดอร์เดี่ยว: cash portion held until payment is confirmed
  isTest         Boolean   @default(false) @map("is_test")
  createdAt      DateTime  @default(now())
}

// Cash portion of a "แบ่งจ่าย" (split: cash + transfer) payment.
// The order's Payment row holds the TRANSFER portion (method PROMPTPAY); this
// row holds the CASH portion so cash vs transfer totals reconcile with the drawer.
// Counted as revenue alongside confirmed Payments, keyed by confirmedAt.
model SplitPayment {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id])
  billId      Int?
  amountTHB   Int
  confirmedAt DateTime @default(now())
  isTest      Boolean  @default(false) @map("is_test")
  createdAt   DateTime @default(now())
}

model CashDrawerSession {
  id            Int      @id @default(autoincrement())
  date          String
  openingFloat  Int      @default(0)
  expectedCash  Int      @default(0)
  totalTransfer Int      @default(0)
  countedCash   Int      @default(0)
  difference    Int      @default(0)
  note          String?
  closedById    Int?
  closedBy      User?    @relation("DrawerClosedBy", fields: [closedById], references: [id])
  isTest        Boolean  @default(false) @map("is_test")
  createdAt     DateTime @default(now())
}

model PaymentConfig {
  id           Int     @id @default(autoincrement())
  promptPayId  String?
  qrImageUrl   String?
  accountName  String  @default("นาย ธนวุฒิ พุ่มมาก")
  bankName     String  @default("TTB PromptPay")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  targetType String?
  targetId   Int?
  detail     String?
  createdAt  DateTime @default(now())
}

model Activity {
  id        Int      @id @default(autoincrement())
  emoji     String
  title     String
  date      String
  tag       String
  desc      String
  imageUrl  String?
  content   String?
  link      String?
  linkLabel String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  section   String   @default("gallery")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GameGuide {
  id          Int     @id @default(autoincrement())
  nameTh      String
  nameEn      String
  summaryTh   String
  rulesTh     String? // คู่มือกติกาละเอียดสำหรับแชทบอทผู้ช่วยสอนเกม (markdown)
  youtubeUrl  String?
  imageUrl    String?
  minPlayers  Int
  maxPlayers  Int
  durationMin Int
  tags        String
  difficulty  String? @default("medium")
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model ExpoPushToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
}

model WerewolfRoom {
  id        Int                  @id @default(autoincrement())
  code      String               @unique
  gmId      Int
  gm        User                 @relation("WerewolfRoomsGM", fields: [gmId], references: [id])
  isOpen    Boolean              @default(true)
  createdAt DateTime             @default(now())
  players   WerewolfRoomPlayer[]
  games     WerewolfGame[]
  session   WerewolfSession?     @relation("WerewolfRoomSession")
}

model WerewolfRoomPlayer {
  id        Int          @id @default(autoincrement())
  roomId    Int
  room      WerewolfRoom @relation(fields: [roomId], references: [id])
  userId    Int
  user      User         @relation("WerewolfRoomPlayers", fields: [userId], references: [id])
  seatName  String
  seatOrder Int          @default(0)
  joinedAt  DateTime     @default(now())

  @@unique([roomId, userId])
}

model WerewolfGame {
  id       Int                  @id @default(autoincrement())
  roomId   Int
  room     WerewolfRoom         @relation(fields: [roomId], references: [id])
  gmId     Int
  gm       User                 @relation("WerewolfGamesGM", fields: [gmId], references: [id])
  winTeam  String
  notes    String?
  playedAt DateTime             @default(now())
  results  WerewolfGameResult[]
  session  WerewolfSession?     @relation("WerewolfSessionGame")
}

model WerewolfGameResult {
  id           Int          @id @default(autoincrement())
  gameId       Int
  game         WerewolfGame @relation(fields: [gameId], references: [id])
  userId       Int
  user         User         @relation("WerewolfGameResults", fields: [userId], references: [id])
  team         String
  role         String
  isWin        Boolean
  pointsEarned Int          @default(0)

  @@unique([gameId, userId])
}

model WerewolfSession {
  id            Int                     @id @default(autoincrement())
  roomId        Int                     @unique
  room          WerewolfRoom            @relation("WerewolfRoomSession", fields: [roomId], references: [id])
  phase         String                  @default("SETUP")
  selectedRoles String
  decoyRoles    String                  @default("[]")
  currentStep   String?
  winTeam       String?
  gameId        Int?                    @unique
  game          WerewolfGame?           @relation("WerewolfSessionGame", fields: [gameId], references: [id])
  nightNumber   Int                     @default(0)
  dayNumber     Int                     @default(0)
  playerCount   Int                     @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  playerRoles   WerewolfSessionPlayer[]
  nightActions  WerewolfNightAction[]
  votes         WerewolfVote[]
}

model WerewolfSessionPlayer {
  id        Int             @id @default(autoincrement())
  sessionId Int
  session   WerewolfSession @relation(fields: [sessionId], references: [id])
  userId    Int
  user      User            @relation("WerewolfSessionPlayers", fields: [userId], references: [id])
  role      String
  team      String
  status    String          @default("alive")

  @@unique([sessionId, userId])
}

model WerewolfNightAction {
  id           Int             @id @default(autoincrement())
  sessionId    Int
  session      WerewolfSession @relation(fields: [sessionId], references: [id])
  night        Int
  actorUserId  Int
  targetUserId Int?
  actionType   String          @default("action")
  createdAt    DateTime        @default(now())

  @@unique([sessionId, night, actorUserId])
}

model WerewolfVote {
  id           Int             @id @default(autoincrement())
  sessionId    Int
  session      WerewolfSession @relation(fields: [sessionId], references: [id])
  day          Int
  voterUserId  Int
  targetUserId Int
  createdAt    DateTime        @default(now())

  @@unique([sessionId, day, voterUserId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("INFO")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model StockItem {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  unit        String
  currentQty  Float    @default(0) @map("current_qty")
  minQty      Float    @default(0) @map("min_qty")
  reorderQty  Float    @default(0) @map("reorder_qty")
  costPerUnit Float    @default(0) @map("cost_per_unit")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  recipes     MenuStockRecipe[]
  stockInLogs  StockInLog[]
  stockOutLogs StockOutLog[]
  alerts       StockAlert[]
  @@map("stock_items")
}

model MenuStockRecipe {
  id          Int       @id @default(autoincrement())
  menuItemId  Int       @map("menu_item_id")
  stockItemId Int       @map("stock_item_id")
  qtyUsed     Float     @map("qty_used")
  size        String    @default("") @map("size")
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  @@unique([menuItemId, stockItemId, size])
  @@map("menu_stock_recipes")
}

model StockInLog {
  id          Int       @id @default(autoincrement())
  stockItemId Int       @map("stock_item_id")
  qty         Float
  note        String?
  createdById Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  createdBy   User      @relation("StockInLogs", fields: [createdById], references: [id])
  @@map("stock_in_log")
}

model StockOutLog {
  id          Int       @id @default(autoincrement())
  stockItemId Int       @map("stock_item_id")
  qty         Float
  reason      String
  orderId     Int?      @map("order_id")
  createdById Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  createdBy   User      @relation("StockOutLogs", fields: [createdById], references: [id])
  @@map("stock_out_log")
}

model StockAlert {
  id          Int        @id @default(autoincrement())
  type        String
  stockItemId Int?       @map("stock_item_id")
  menuItemId  Int?       @map("menu_item_id")
  message     String
  isRead      Boolean    @default(false) @map("is_read")
  createdAt   DateTime   @default(now()) @map("created_at")
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id])
  @@map("stock_alerts")
}

model Receipt {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique
  orderName     String   @default("")
  totalTHB      Int                  // NET total actually paid (after discount)
  discountAmount Int?                // discount applied (subtotal = totalTHB + discountAmount)
  paymentMethod String
  locationLabel String   @default("")
  itemsJson     String
  confirmedAt   DateTime
  isTest        Boolean  @default(false) @map("is_test")
  createdAt     DateTime @default(now())
}

model Discount {
  id        Int      @id @default(autoincrement())
  nameTh    String   @map("name_th")
  type      String   @default("FIXED") // "PERCENT" | "FIXED"
  value     Int      @default(0)
  isActive  Boolean  @default(true)    @map("is_active")
  createdAt DateTime @default(now())   @map("created_at")
}

model CashExpense {
  id          Int      @id @default(autoincrement())
  type        String   // "PETTY_CASH" | "STAFF_ADVANCE"
  amount      Int
  description String
  photoUrl    String?
  note        String?
  reimbursed  Boolean  @default(false)
  isTest      Boolean  @default(false) @map("is_test")
  createdAt   DateTime @default(now())
}

model CashTopup {
  id          Int      @id @default(autoincrement())
  amount      Int
  description String
  note        String?
  photoUrl    String?
  createdById Int?
  isTest      Boolean  @default(false) @map("is_test")
  createdAt   DateTime @default(now())
}

model ShopSession {
  id           Int       @id @default(1)
  isOpen       Boolean   @default(false) @map("is_open")
  openedAt     DateTime? @map("opened_at")
  closedAt     DateTime? @map("closed_at")
  openedById   Int?      @map("opened_by")
  openingFloat Int?      @map("opening_float") // เงินเปิดเก๊ะ — persisted so it survives midnight / device switch
  openedBy     User?     @relation("ShopSessions", fields: [openedById], references: [id])
  @@map("shop_session")
}

// ── HR Module ──────────────────────────────────────────────────────────────

model HrStaff {
  id                    Int          @id @default(autoincrement())
  userId                Int          @unique @map("user_id")
  pin                   String?
  faceData              String?      @map("face_data")
  credentialId          String?      @map("credential_id")
  credentialPublicKey   String?      @map("credential_public_key")
  credentialCounter     Int          @default(0) @map("credential_counter")
  pendingChallenge      String?      @map("pending_challenge")
  azurePersonId         String?      @map("azure_person_id")
  baseSalary            Int          @default(0) @map("base_salary")
  payType               String       @default("MONTHLY") @map("pay_type")
  createdAt             DateTime     @default(now()) @map("created_at")
  user                  User         @relation("HrStaff", fields: [userId], references: [id])
  attendances           HrAttendance[]
  checklists            HrChecklist[]
  checklistItemsDone    HrChecklistItem[] @relation("ChecklistItemDoneBy")
  tasks                 HrTask[]     @relation("HrTaskAssignee")
  kpis                  HrKpi[]
  schedules             HrSchedule[]
  deductions            HrDeduction[]
  paymentEvents         HrPaymentEvent[]
  @@map("hr_staff")
}

model HrDeduction {
  id         Int      @id @default(autoincrement())
  staffId    Int      @map("staff_id")
  amount     Int
  reason     String
  note       String?
  month      Int
  year       Int
  sourceType String?  @map("source_type") // LATE | ABSENT | TASK | CHECKLIST | null (manual)
  sourceId   String?  @map("source_id")   // stable idempotency key per source
  createdAt  DateTime @default(now()) @map("created_at")
  isTest     Boolean  @default(false) @map("is_test")
  staff      HrStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  @@unique([sourceType, sourceId])
  @@index([staffId, year, month])
  @@map("hr_deduction")
}

model HrSchedule {
  id            Int      @id @default(autoincrement())
  staffId       Int      @map("staff_id")
  dayOfWeek     Int      @map("day_of_week")
  startTime     String   @map("start_time")
  endTime       String   @map("end_time")
  graceMinutes  Int      @default(10) @map("grace_minutes")
  staff         HrStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  @@unique([staffId, dayOfWeek])
  @@map("hr_schedule")
}

model HrAttendance {
  id                    Int       @id @default(autoincrement())
  staffId               Int       @map("staff_id")
  checkIn               DateTime  @map("check_in")
  checkOut              DateTime? @map("check_out")
  photoUrl              String?   @map("photo_url")
  checkInStatus         String?   @map("check_in_status")
  checkOutStatus        String?   @map("check_out_status")
  lateDeductionApplied  Boolean   @default(false) @map("late_deduction_applied")
  createdAt             DateTime  @default(now()) @map("created_at")
  isTest                Boolean   @default(false) @map("is_test")
  staff                 HrStaff   @relation(fields: [staffId], references: [id])
  @@map("hr_attendance")
}

model HrLateConfig {
  id                    Int      @id @default(autoincrement())
  deductionType         String   @default("FIXED") @map("deduction_type")
  deductionAmount       Int      @default(0) @map("deduction_amount")
  absentDeductionAmount Int      @default(0) @map("absent_deduction_amount")
  absentDeductionType   String   @default("FIXED") @map("absent_deduction_type")
  taskDeductionAmount   Int      @default(0) @map("task_deduction_amount")
  taskDeductionType     String   @default("FIXED") @map("task_deduction_type")
  lateDeductionMax      Int      @default(0) @map("late_deduction_max")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")
  @@map("hr_late_config")
}

model HrChecklist {
  id               Int               @id @default(autoincrement())
  type             String            // "OPEN" | "CLOSE"
  date             DateTime
  staffId          Int               @map("staff_id")
  startedAt        DateTime?         @default(now()) @map("started_at")
  deductionApplied Boolean           @default(false) @map("deduction_applied")
  createdAt        DateTime          @default(now()) @map("created_at")
  isTest           Boolean           @default(false) @map("is_test")
  staff            HrStaff           @relation(fields: [staffId], references: [id])
  items            HrChecklistItem[]
  @@map("hr_checklist")
}

model HrChecklistConfig {
  id                 Int      @id @default(autoincrement())
  type               String   @unique // "OPEN" | "CLOSE"
  timeLimitMinutes   Int?     @map("time_limit_minutes")
  deductionAmount    Int      @default(0) @map("deduction_amount")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  @@map("hr_checklist_config")
}

model HrChecklistItem {
  id            Int                  @id @default(autoincrement())
  checklistId   Int                  @map("checklist_id")
  templateId    Int?                 @map("template_id")
  label         String
  section       String?
  done          Boolean              @default(false)
  photoUrl      String?              @map("photo_url")
  doneAt        DateTime?            @map("done_at")
  doneBy        Int?                 @map("done_by")
  requiresPhoto Boolean              @default(false) @map("requires_photo")
  isTest        Boolean              @default(false) @map("is_test")
  checklist     HrChecklist          @relation(fields: [checklistId], references: [id])
  template      HrChecklistTemplate? @relation(fields: [templateId], references: [id])
  doneByStaff   HrStaff?             @relation("ChecklistItemDoneBy", fields: [doneBy], references: [id])
  @@map("hr_checklist_item")
}

model HrChecklistTemplate {
  id            Int               @id @default(autoincrement())
  type          String            // "OPEN" | "CLOSE"
  section       String?
  label         String
  order         Int               @default(0)
  requiresPhoto Boolean           @default(false) @map("requires_photo")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  items         HrChecklistItem[]
  @@map("hr_checklist_template")
}

model HrTask {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      String    @default("TODO") // "TODO" | "IN_PROGRESS" | "DONE"
  assignedTo  Int?      @map("assigned_to")
  deadline    DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")
  isTest      Boolean   @default(false) @map("is_test")
  assignee    HrStaff?  @relation("HrTaskAssignee", fields: [assignedTo], references: [id])
  @@map("hr_task")
}

model HrKpi {
  id        Int     @id @default(autoincrement())
  staffId   Int     @map("staff_id")
  title     String
  target    Float
  actual    Float   @default(0)
  unit      String
  month     Int
  year      Int
  isTest    Boolean @default(false) @map("is_test")
  staff     HrStaff @relation(fields: [staffId], references: [id])
  @@map("hr_kpi")
}

model HrPaymentEvent {
  id          Int       @id @default(autoincrement())
  staffId     Int?      @map("staff_id")
  date        DateTime
  amount      Int
  description String
  type        String    @default("SALARY")  // SALARY|BONUS|ADVANCE|COMMISSION|HOLIDAY|APPOINTMENT|OTHER
  recurrence      String?   // null = once, "MONTHLY" = every month same day
  notifyDaysBefore Int?    @map("notify_days_before")  // null = no notification
  isPaid      Boolean   @default(false) @map("is_paid")
  paidAt      DateTime? @map("paid_at")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  isTest      Boolean   @default(false) @map("is_test")
  staff       HrStaff?  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  @@index([date])
  @@index([staffId])
  @@map("hr_payment_event")
}
